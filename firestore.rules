rules_version = '2';

// ─────────────────────────────────────────────────────────────────────────────
// Debug the Diet — Firestore Security Rules
//
// HOW TO DEPLOY (two options):
//
// Option A — Firebase Console (easiest, no CLI needed):
//   1. Go to https://console.firebase.google.com/project/debug-the-diet/firestore/rules
//   2. Paste the rules below into the editor and click "Publish"
//
// Option B — Firebase CLI:
//   1. npm install -g firebase-tools
//   2. firebase login
//   3. firebase use debug-the-diet
//   4. firebase deploy --only firestore:rules
// ─────────────────────────────────────────────────────────────────────────────

service cloud.firestore {
  match /databases/{database}/documents {

    // Each user can only read and write their own document tree.
    // This covers ALL subcollections: meals, sleep, and any future ones.
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

  }
}
